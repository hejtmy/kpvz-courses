---
export interface Props {
  href: string;
  label: string;
  variant?: 'primary' | 'secondary' | 'ghost';
  external?: boolean;
}

const { href, label, variant = 'primary', external = false } = Astro.props;
const externalProps = external ? { target: '_blank', rel: 'noopener' } : {};
---

<a class={`fhs-button fhs-button--${variant} not-content`} href={href} {...externalProps}>
  {label}{external ? ' ↗' : ' →'}
</a>

<style>
  .fhs-button {
    display: inline-block;
    font-family: var(--font-headline);
    font-weight: 700;
    font-size: 0.95rem;
    letter-spacing: 0.01em;
    padding: 0.55em 1.1em;
    border: 2px solid var(--fhs-black);
    border-radius: 0;
    box-shadow: 4px 4px 0 0 var(--fhs-black);
    text-decoration: none !important;
    transition: transform 80ms ease, box-shadow 80ms ease, background 100ms ease, color 100ms ease;
    cursor: pointer;
    line-height: 1.3;
  }
  .fhs-button:active {
    transform: translate(4px, 4px);
    box-shadow: 0 0 0 0 transparent;
  }

  /* primary — black fill */
  .fhs-button--primary {
    background: var(--fhs-black);
    color: var(--fhs-paper) !important;
  }
  .fhs-button--primary:hover {
    background: var(--fhs-magenta);
    border-color: var(--fhs-magenta);
    box-shadow: 4px 4px 0 0 var(--fhs-black);
    color: var(--fhs-paper) !important;
  }

  /* secondary — yellow fill */
  .fhs-button--secondary {
    background: var(--fhs-yellow);
    color: var(--fhs-black) !important;
  }
  .fhs-button--secondary:hover {
    background: var(--fhs-magenta);
    border-color: var(--fhs-magenta);
    box-shadow: 4px 4px 0 0 var(--fhs-black);
    color: var(--fhs-paper) !important;
  }

  /* ghost — transparent, border only */
  .fhs-button--ghost {
    background: transparent;
    color: var(--fhs-black) !important;
  }
  .fhs-button--ghost:hover {
    background: var(--fhs-yellow);
    box-shadow: 4px 4px 0 0 var(--fhs-black);
    color: var(--fhs-black) !important;
  }

  /* dark mode */
  :global([data-theme='dark']) .fhs-button {
    border-color: var(--fhs-paper);
    box-shadow: 4px 4px 0 0 var(--fhs-paper);
  }
  :global([data-theme='dark']) .fhs-button--primary {
    background: var(--fhs-paper);
    color: var(--fhs-black) !important;
  }
  :global([data-theme='dark']) .fhs-button--primary:hover {
    background: var(--fhs-magenta);
    border-color: var(--fhs-magenta);
    box-shadow: 4px 4px 0 0 var(--fhs-paper);
    color: var(--fhs-paper) !important;
  }
  :global([data-theme='dark']) .fhs-button--secondary {
    background: var(--fhs-yellow);
    color: var(--fhs-black) !important;
    border-color: var(--fhs-paper);
  }
  :global([data-theme='dark']) .fhs-button--ghost {
    background: transparent;
    color: var(--fhs-paper) !important;
  }
  :global([data-theme='dark']) .fhs-button--ghost:hover {
    background: var(--fhs-magenta);
    border-color: var(--fhs-magenta);
    color: var(--fhs-paper) !important;
  }
  :global([data-theme='dark']) .fhs-button:active {
    box-shadow: 0 0 0 0 transparent;
  }
</style>
