---
interface Props {
  src: string;
}

const { src } = Astro.props;
---

<div class="canva-embed">
  <iframe
    loading="lazy"
    src={src}
    allowfullscreen="allowfullscreen"
    allow="fullscreen"
  ></iframe>
</div>

<style>
  .canva-embed {
    position: relative;
    width: 100%;
    height: 0;
    padding-top: 56.25%;
    box-shadow: 0 2px 8px 0 rgba(63, 69, 81, 0.16);
    overflow: hidden;
    border-radius: 8px;
    will-change: transform;
  }

  .canva-embed iframe {
    position: absolute;
    width: 100%;
    height: 100%;
    top: 0;
    left: 0;
    border: none;
    padding: 0;
    margin: 0;
  }
</style>
